<Window
    x:Class="TrucoWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TrucoWinUI.ViewModels"
    Title="Truco - Native Windows">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootPanel">
        <Grid.DataContext>
            <local:AppShellViewModel/>
        </Grid.DataContext>
        
        <!-- Background Wood -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4A2A18" Offset="0"/>
                    <GradientStop Color="#542F1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        
        <!-- Background Felt -->
        <Border CornerRadius="80" Margin="32" BorderThickness="2" BorderBrush="#22FFFFFF" Background="#114e25">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
        </Border>
        
        <Grid Margin="32">
            
            <!-- HUD (Absolute Top) -->
            <Grid VerticalAlignment="Top" Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Vertical" Background="#AA000000" Padding="16,12" CornerRadius="8" HorizontalAlignment="Left" MinWidth="100">
                    <TextBlock Text="NÓS" FontSize="14" FontWeight="Bold" Foreground="LightGray" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding UsPoints, FallbackValue=0}" FontSize="32" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Vertical" Background="#CC000000" Padding="24,12" CornerRadius="12" BorderThickness="2" BorderBrush="#FFCC00" HorizontalAlignment="Center">
                    <TextBlock Text="VALE" FontSize="16" FontWeight="Bold" Foreground="LightGray" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Snapshot.CurrentHand.Stake, FallbackValue=1}" FontSize="32" FontWeight="Black" Foreground="#FFCC00" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Vertical" Background="#AA000000" Padding="16,12" CornerRadius="8" HorizontalAlignment="Right" MinWidth="100">
                    <TextBlock Text="ELES" FontSize="14" FontWeight="Bold" Foreground="LightGray" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ThemPoints, FallbackValue=0}" FontSize="32" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
            
            <!-- Menu State -->
            <StackPanel Visibility="{Binding VisibilityIfNotPlaying}" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.RowSpan="3" Spacing="16">
                <TextBlock Text="Truco WinUI 3" FontSize="72" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,32">
                    <TextBlock.Shadow>
                        <ThemeShadow />
                    </TextBlock.Shadow>
                </TextBlock>

                <Border Background="#AA3B0D0D" BorderBrush="#FFB3B3" BorderThickness="1" CornerRadius="10" Padding="12,10" Width="280" Visibility="{Binding VisibilityIfLastActionError}">
                    <TextBlock Text="{Binding CombinedErrorText}" Foreground="#FFFFD9D9" TextWrapping="Wrap"/>
                </Border>

                <TextBox Header="Seu nome" Text="{Binding SetupPlayerName, Mode=TwoWay}" Width="280"/>
                <ComboBox Header="Jogadores" SelectedIndex="{Binding SetupNumPlayersIndex, Mode=TwoWay}" Width="280">
                    <ComboBoxItem Content="2 jogadores"/>
                    <ComboBoxItem Content="4 jogadores"/>
                </ComboBox>
                <ComboBox Header="Idioma" SelectedIndex="{Binding SetupLocaleIndex, Mode=TwoWay}" Width="280">
                    <ComboBoxItem Content="Português (Brasil)"/>
                    <ComboBoxItem Content="English (US)"/>
                </ComboBox>
                <TextBox Header="Relay URL (opcional)" Text="{Binding SetupRelayUrl, Mode=TwoWay}" Width="280"/>
                <ComboBox Header="Papel ao entrar" SelectedIndex="{Binding SetupDesiredRoleIndex, Mode=TwoWay}" Width="280">
                    <ComboBoxItem Content="Auto"/>
                    <ComboBoxItem Content="Parceiro"/>
                    <ComboBoxItem Content="Adversário"/>
                </ComboBox>
                
                <Button Content="Jogar Offline" Command="{Binding StartGameCommand}" Width="280" Height="50" FontSize="16" Background="#FFCC00" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" CornerRadius="8"/>
                <Button Content="Criar Sala (Host)" Command="{Binding HostOnlineGameCommand}" Width="280" Height="50" FontSize="16" Background="#444444" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" CornerRadius="8"/>
                
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBox PlaceholderText="Código do convite" Text="{Binding InviteKeyInput, Mode=TwoWay}" Width="192" Height="50" FontSize="16" VerticalAlignment="Center"/>
                    <Button Content="Entrar" Command="{Binding JoinOnlineGameCommand}" Width="80" Height="50" Background="#444444" Foreground="White" FontWeight="Bold" CornerRadius="8" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Online Lobby State -->
            <Grid Visibility="{Binding VisibilityIfOnlineLobby}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="40" Grid.RowSpan="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="16" Margin="0,0,20,0">
                    <TextBlock Text="Sala Online" FontSize="36" FontWeight="Black" Foreground="White"/>
                    <TextBlock Text="{Binding LobbyStatusText}" Foreground="#FFE7D9B6" FontSize="14"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding VisibilityIfInviteKey}">
                        <TextBlock Text="Chave:" FontSize="16" Foreground="LightGray" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding InviteKeyText}" IsReadOnly="True" Width="200" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#FFCC00"/>
                        <Button Content="Copiar" Command="{Binding CopyInviteKeyCommand}" VerticalAlignment="Center" Padding="12,6"/>
                    </StackPanel>
                    
                    <Border Background="#22000000" CornerRadius="8" Padding="16">
                        <StackPanel Orientation="Vertical" Spacing="12">
                            <TextBlock Text="Jogadores" FontWeight="Bold" Foreground="White"/>
                            
                            <ItemsControl ItemsSource="{Binding LobbySlots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding Label}" Foreground="White" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="#FFCC00" FontSize="12"/>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Content="Votar Host"
                                                    Command="{Binding DataContext.VoteHostCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Seat}"
                                                    IsEnabled="{Binding CanVote}"
                                                    Margin="0,0,8,0"/>
                                            <Button Grid.Column="2"
                                                    Content="Convite"
                                                    Command="{Binding DataContext.RequestReplacementInviteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Seat}"
                                                    IsEnabled="{Binding CanReplace}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                        </StackPanel>
                    </Border>

                    <Border Background="#22000000" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Rede e controle" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Status" Foreground="Gray"/>
                                <TextBlock Text="{Binding ConnectionStatusText}" Foreground="LightGray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Modo" Foreground="Gray"/>
                                <TextBlock Text="{Binding ConnectionModeText}" Foreground="LightGray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding VisibilityIfConnectionRole}">
                                <TextBlock Text="Papel" Foreground="Gray"/>
                                <TextBlock Text="{Binding ConnectionRoleText}" Foreground="LightGray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Fila" Foreground="Gray"/>
                                <TextBlock Text="{Binding EventBacklogText}" Foreground="LightGray"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CombinedErrorText}" Foreground="#FFB3B3" TextWrapping="Wrap" Visibility="{Binding VisibilityIfCombinedError}"/>
                            <Button Content="Atualizar" Command="{Binding RefreshStateCommand}" HorizontalAlignment="Left" Padding="12,6"/>
                        </StackPanel>
                    </Border>
                    
                    <Button Content="Iniciar Partida" Command="{Binding StartHostedMatchCommand}" Width="280" Height="50" Background="#00AA00" Foreground="White" FontWeight="Bold" CornerRadius="8" Visibility="{Binding VisibilityIfHost}"/>
                    <Button Content="Sair da Sala" Command="{Binding LeaveOnlineGameCommand}" Width="280" Height="40" Background="#AA0000" Foreground="White" FontWeight="Bold" CornerRadius="8"/>
                </StackPanel>
                
                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="160"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Chat" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    
                    <Border Grid.Row="1" Background="#33000000" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ChatEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="White" TextWrapping="Wrap" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="2" Background="#22000000" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Eventos da sala" FontWeight="Bold" Foreground="White"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding LobbyEventEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="LightGray" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                    
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ChatMessage, Mode=TwoWay}" PlaceholderText="Mensagem..." Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Enviar" Command="{Binding SendChatCommand}" Background="#FFCC00" Foreground="Black" FontWeight="Bold" CornerRadius="8"/>
                    </Grid>
                </Grid>
            </Grid>
            
            <!-- Active Game State -->
            <Grid Visibility="{Binding VisibilityIfPlaying}" Margin="0,100,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- Top Player (Opponent or Teammate) -->
                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0">
                    <TextBlock Text="{Binding TopPlayer.Name}" FontSize="16" FontWeight="Bold" Foreground="LightGray" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <!-- Cards Face Down -->
                    <ItemsControl ItemsSource="{Binding TopPlayer.Hand}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="64" Height="92" Background="#113e25" CornerRadius="6" BorderBrush="#88FFFFFF" BorderThickness="1" Margin="-40,0,0,0">
                                    <TextBlock Text="✦" Foreground="#88FFFFFF" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Left Player -->
                <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="40,0,0,0" Visibility="{Binding LeftPlayerVisibility}">
                    <!-- Wait, Converter x:Null isn't available by default. Simple fallback is empty bindings -->
                    <TextBlock Text="{Binding LeftPlayer.Name}" FontSize="16" FontWeight="Bold" Foreground="LightGray" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding LeftPlayer.Hand}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="92" Height="64" Background="#113e25" CornerRadius="6" BorderBrush="#88FFFFFF" BorderThickness="1" Margin="0,-40,0,0">
                                    <TextBlock Text="✦" Foreground="#88FFFFFF" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform Angle="90" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Right Player -->
                <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,40,0">
                    <TextBlock Text="{Binding RightPlayer.Name}" FontSize="16" FontWeight="Bold" Foreground="LightGray" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding RightPlayer.Hand}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="92" Height="64" Background="#113e25" CornerRadius="6" BorderBrush="#88FFFFFF" BorderThickness="1" Margin="0,-40,0,0">
                                    <TextBlock Text="✦" Foreground="#88FFFFFF" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform Angle="90" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Center Table -->
                <Grid Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" ColumnSpacing="60">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Vira -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="VIRA" FontSize="14" FontWeight="Bold" Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                        <Border Width="86" Height="124" Background="White" CornerRadius="8" Margin="0,8,0,0">
                            <Grid>
                                <TextBlock Text="{Binding Snapshot.CurrentHand.Vira.Rank, FallbackValue=?}" Margin="6,4,0,0" FontSize="18" FontWeight="Bold" Foreground="Black"/>
                                <TextBlock Text="{Binding Snapshot.CurrentHand.Vira.SuitSymbol, FallbackValue=♠}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="42" Foreground="{Binding Snapshot.CurrentHand.Vira.ColorBrush, FallbackValue=Black}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                    
                    <!-- Round Cards Played -->
                    <Grid Grid.Column="1" Width="220" Height="220">
                        <Ellipse Stroke="White" StrokeThickness="2" Opacity="0.1" />
                        <ItemsControl ItemsSource="{Binding Snapshot.CurrentHand.RoundCards}" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="86" Height="124" Background="White" CornerRadius="8" BorderBrush="LightGray" BorderThickness="1" Margin="-30,0,0,0">
                                        <Border.Shadow>
                                            <ThemeShadow />
                                        </Border.Shadow>
                                        <Grid>
                                            <TextBlock Text="{Binding Card.Rank}" Margin="6,4,0,0" FontSize="18" FontWeight="Bold" Foreground="Black"/>
                                            <TextBlock Text="{Binding Card.SuitSymbol}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="42" Foreground="{Binding Card.ColorBrush, FallbackValue=Black}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                    
                    <!-- Manilha Indicator -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="MANILHA" FontSize="14" FontWeight="Bold" Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                        <Border Width="86" Height="124" Background="#33FFCC00" BorderBrush="#FFCC00" BorderThickness="2" CornerRadius="8" Margin="0,8,0,0">
                            <TextBlock Text="{Binding Snapshot.CurrentHand.Manilha, FallbackValue=4}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="46" FontWeight="Black" Foreground="#FFCC00"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- My Hand & Actions (Bottom Player) -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,24">
                    
                    <!-- Match Over Screen Overlay -->
                    <StackPanel Visibility="{Binding VisibilityIfMatchOver}" Background="#DD000000" Padding="60,30" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="{Binding MatchResultText}" FontSize="64" FontWeight="Black" Foreground="#FFCC00" HorizontalAlignment="Center" />
                        <Button Content="NOVA PARTIDA" Command="{Binding StartGameCommand}" Width="200" Height="40" Background="White" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,0" CornerRadius="8"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <!-- Request Truco -->
                        <Button Visibility="{Binding VisibilityIfAskTruco}" Content="{Binding AskTrucoLabel}" Command="{Binding RequestTrucoCommand}" Background="#FF0000" Foreground="White" FontWeight="Bold" CornerRadius="8" Height="40" MinWidth="120" Margin="0,0,16,0" />
                        
                        <!-- Response Actions -->
                        <StackPanel Orientation="Horizontal" Visibility="{Binding VisibilityIfShowTruco}">
                            <Button Content="ACEITAR" Command="{Binding AcceptTrucoCommand}" Background="#00AA00" Foreground="White" FontWeight="Bold" CornerRadius="8" Height="40" MinWidth="120" Margin="0,0,16,0" />
                            <Button Content="CRAVAR" Command="{Binding RequestTrucoCommand}" Background="#FF0000" Foreground="White" FontWeight="Bold" CornerRadius="8" Height="40" MinWidth="120" Margin="0,0,16,0" />
                            <Button Content="CORRER" Command="{Binding RefuseTrucoCommand}" Background="#333333" Foreground="White" FontWeight="Bold" CornerRadius="8" Height="40" MinWidth="120" />
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Turn Indicator -->
                    <Border Background="#FFCC00" CornerRadius="16" Padding="12,4" Margin="0,0,0,10" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MatchStatusText}" FontSize="12" FontWeight="Bold" Foreground="Black" />
                    </Border>

                    <Border Background="#66000000" CornerRadius="12" Padding="14,10" Margin="0,0,0,16" HorizontalAlignment="Center" Visibility="{Binding VisibilityIfLastActionError}">
                        <TextBlock Text="{Binding CombinedErrorText}" Foreground="#FFFFD9D9" TextWrapping="Wrap" MaxWidth="420"/>
                    </Border>
                    
                    <!-- My Cards -->
                    <ItemsControl ItemsSource="{Binding Me.Hand}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.PlayCardCommand, ElementName=RootPanel}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding DataContext.CanPlayCards, ElementName=RootPanel}"
                                        Background="Transparent" BorderThickness="0" Padding="0" Margin="20,0,0,0">
                                    
                                    <Button.Resources>
                                        <Storyboard x:Key="PointerEnteredStoryboard">
                                            <DoubleAnimation Storyboard.TargetName="CardTranslateTransform"
                                                             Storyboard.TargetProperty="Y"
                                                             To="-20" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                             Storyboard.TargetProperty="(UIElement.Shadow).(ThemeShadow.Scale)"
                                                             To="1.15" Duration="0:0:0.2" />
                                        </Storyboard>
                                        <Storyboard x:Key="PointerExitedStoryboard">
                                            <DoubleAnimation Storyboard.TargetName="CardTranslateTransform"
                                                             Storyboard.TargetProperty="Y"
                                                             To="0" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                             Storyboard.TargetProperty="(UIElement.Shadow).(ThemeShadow.Scale)"
                                                             To="1.0" Duration="0:0:0.3" />
                                        </Storyboard>
                                    </Button.Resources>
                                    
                                    <Border x:Name="CardBorder" Width="100" Height="140" Background="White" CornerRadius="8" BorderBrush="LightGray" BorderThickness="1"
                                            PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="CardTranslateTransform" Y="0" />
                                        </Border.RenderTransform>
                                        <Border.Shadow>
                                            <ThemeShadow />
                                        </Border.Shadow>
                                        <Grid>
                                            <TextBlock Text="{Binding Rank}" Margin="8,6,0,0" FontSize="20" FontWeight="Bold" Foreground="Black"/>
                                            <TextBlock Text="{Binding SuitSymbol}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="56" Foreground="{Binding ColorBrush, FallbackValue=Black}"/>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
            
            <!-- Global Logs / Events Banner overlay (Optional) -->
            <StackPanel Visibility="{Binding VisibilityIfPlaying}" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="24,0,0,24" MinWidth="340" Spacing="10">
                <Border Background="#66000000" CornerRadius="8" Padding="16" MaxHeight="160">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Log da partida" Foreground="White" FontWeight="Bold"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding MatchLogEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="LightGray" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Background="#66000000" CornerRadius="8" Padding="16" MaxHeight="160">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Eventos do runtime" Foreground="White" FontWeight="Bold"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding EventLogEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="LightGray" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Visibility="{Binding VisibilityIfOnlineMatch}" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,24,24" Width="320">
                <Border Background="#66000000" CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Chat" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                            <ItemsControl ItemsSource="{Binding ChatEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="LightGray" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ChatMessage, Mode=TwoWay}" PlaceholderText="Mensagem..." Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Enviar" Command="{Binding SendChatCommand}" Background="#FFCC00" Foreground="Black" FontWeight="Bold" CornerRadius="8"/>
                        </Grid>
                    </Grid>
                </Border>
                <Border Background="#66000000" CornerRadius="8" Padding="12" Margin="0,10,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Rede e controle" Foreground="White" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Status" Foreground="Gray"/>
                            <TextBlock Text="{Binding ConnectionStatusText}" Foreground="LightGray"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Modo" Foreground="Gray"/>
                            <TextBlock Text="{Binding ConnectionModeText}" Foreground="LightGray"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding VisibilityIfConnectionRole}">
                            <TextBlock Text="Papel" Foreground="Gray"/>
                            <TextBlock Text="{Binding ConnectionRoleText}" Foreground="LightGray"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Fila" Foreground="Gray"/>
                            <TextBlock Text="{Binding EventBacklogText}" Foreground="LightGray"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CombinedErrorText}" Foreground="#FFB3B3" TextWrapping="Wrap" Visibility="{Binding VisibilityIfCombinedError}"/>
                        <ItemsControl ItemsSource="{Binding LobbySlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="4" Margin="0,4,0,4">
                                        <TextBlock Text="{Binding Label}" Foreground="White" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding StatusText}" Foreground="#FFCC00" FontSize="12"/>
                                            <Button Content="Votar host"
                                                    Command="{Binding DataContext.VoteHostCommand, ElementName=RootPanel}"
                                                    CommandParameter="{Binding Seat}"
                                                    IsEnabled="{Binding CanVote}"
                                                    Padding="8,4"/>
                                            <Button Content="Substituir"
                                                    Command="{Binding DataContext.RequestReplacementInviteCommand, ElementName=RootPanel}"
                                                    CommandParameter="{Binding Seat}"
                                                    IsEnabled="{Binding CanReplace}"
                                                    Padding="8,4"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Atualizar" Command="{Binding RefreshStateCommand}" Padding="12,6"/>
                            <Button Content="Sair da mesa" Command="{Binding LeaveMatchCommand}" Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

        </Grid>
    </Grid>
</Window>
