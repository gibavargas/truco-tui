<Window
    x:Class="TrucoWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:TrucoWinUI.Converters"
    xmlns:viewModels="using:TrucoWinUI.ViewModels"
    Title="Truco Paulista">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootPanel" Loaded="RootPanel_Loaded" SizeChanged="RootPanel_SizeChanged">
        <Grid.DataContext>
            <viewModels:AppShellViewModel />
        </Grid.DataContext>
        <Grid.Resources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
            <converters:SuitToBrushConverter x:Key="SuitToBrushConverter" />

            <!-- Core mac-parity colors -->
            <SolidColorBrush x:Key="MacTextPrimary" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="MacTextMuted" Color="#B3FFFFFF" />
            <SolidColorBrush x:Key="MacTextYellow" Color="#FFFFD54F" />
            <SolidColorBrush x:Key="MacTextDark" Color="#FF4E342E" />

            <LinearGradientBrush x:Key="MacWoodBackground" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#5E3622" Offset="0" />
                <GradientStop Color="#422514" Offset="1" />
            </LinearGradientBrush>

            <RadialGradientBrush x:Key="MacFeltBrush" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                <GradientStop Color="#1E7338" Offset="0" />
                <GradientStop Color="#0D331A" Offset="1" />
            </RadialGradientBrush>

            <Style x:Key="MacPillText" TargetType="Border">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Background" Value="#80000000" />
                <Setter Property="Padding" Value="16,6" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <Style x:Key="MacScoreBadge" TargetType="Border">
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Background" Value="#66000000" />
                <Setter Property="BorderBrush" Value="#1AFFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Width" Value="80" />
                <Setter Property="Height" Value="80" />
            </Style>

            <Style x:Key="MacStakeBadge" TargetType="Border" BasedOn="{StaticResource MacScoreBadge}">
                <Setter Property="BorderBrush" Value="#99FFD54F" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="Width" Value="90" />
            </Style>

            <DataTemplate x:Key="GameCardTemplate">
                <Border Width="110" Height="156" CornerRadius="12" BorderBrush="#D6B16A" BorderThickness="1" Visibility="{Binding CardVisibility, FallbackValue=Collapsed}">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" CenterX="55" CenterY="78" />
                            <RotateTransform Angle="{Binding Rotation}" CenterX="55" CenterY="78" />
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFDF8" Offset="0" />
                            <GradientStop Color="#EADCC1" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Visibility="{Binding IsFaceUp, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="-2">
                                <TextBlock Text="{Binding Card.Rank}" Foreground="{Binding Card.IsRed, Converter={StaticResource SuitToBrushConverter}}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Card.SuitSymbol}" Foreground="{Binding Card.IsRed, Converter={StaticResource SuitToBrushConverter}}" FontSize="14" />
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <TextBlock Text="{Binding Card.SuitSymbol}" FontSize="52" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Card.IsRed, Converter={StaticResource SuitToBrushConverter}}" Opacity="0.8"/>
                            </Grid>

                            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Spacing="-2">
                                <StackPanel.RenderTransform>
                                    <RotateTransform Angle="180" />
                                </StackPanel.RenderTransform>
                                <TextBlock Text="{Binding Card.Rank}" Foreground="{Binding Card.IsRed, Converter={StaticResource SuitToBrushConverter}}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding Card.SuitSymbol}" Foreground="{Binding Card.IsRed, Converter={StaticResource SuitToBrushConverter}}" FontSize="14" HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>

                        <Grid Visibility="{Binding IsFaceUp, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                            <Border CornerRadius="8" Background="#112433" BorderBrush="#339FC08A" BorderThickness="1">
                                <Grid>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="TP" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#F5DE9B" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate>
            
            <DataTemplate x:Key="ActivityEntryTemplate">
                <Border CornerRadius="8" Padding="10" Background="#1A000000" Margin="0,0,0,8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="60" Height="24" CornerRadius="12" Background="{Binding Accent, Converter={StaticResource HexToBrushConverter}}">
                            <TextBlock Text="{Binding ChannelLabel}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1A1110" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{Binding Timestamp}" Foreground="{StaticResource MacTextMuted}" FontSize="11" />
                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource MacTextPrimary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
            
            <DataTemplate x:Key="LogEntryTemplate">
                <Border CornerRadius="8" Padding="10" Background="#1A000000" Margin="0,0,0,6">
                    <TextBlock Text="{Binding}" Foreground="{StaticResource MacTextMuted}" TextWrapping="Wrap" FontSize="12"/>
                </Border>
            </DataTemplate>

            <Style x:Key="CardButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid" Background="Transparent">
                                <Grid.RenderTransform>
                                    <TranslateTransform x:Name="HoverTranslate" Y="0" />
                                </Grid.RenderTransform>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverTranslate" Storyboard.TargetProperty="Y" To="-20" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverTranslate" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter Content="{TemplateBinding Content}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid Background="{StaticResource MacWoodBackground}">
            <!-- Wood Planks Effect -->
            <Grid Opacity="0.2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,2,0"/>
                <Border Grid.Column="1" BorderBrush="Black" BorderThickness="0,0,2,0"/>
                <Border Grid.Column="2" BorderBrush="Black" BorderThickness="0,0,2,0"/>
                <Border Grid.Column="3" BorderBrush="Black" BorderThickness="0,0,2,0"/>
                <Border Grid.Column="4" BorderBrush="Black" BorderThickness="0,0,2,0"/>
                <Border Grid.Column="5" BorderBrush="Black" BorderThickness="0,0,2,0"/>
                <Border Grid.Column="6" BorderBrush="Black" BorderThickness="0,0,2,0"/>
                <Border Grid.Column="7" BorderBrush="Black" BorderThickness="0,0,2,0"/>
            </Grid>

            <!-- Main Layout -->
            <Grid Margin="20" RowSpacing="16" x:Name="GameLayoutGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" x:Name="GameMainRow" />
                    <RowDefinition Height="*" x:Name="GameSidebarRow" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" x:Name="GameMainColumn" />
                    <ColumnDefinition Width="340" x:Name="GameSidebarColumn" />
                </Grid.ColumnDefinitions>

                <!-- Modern translucent header replacing the rustic one -->
                <Border Grid.Row="0" Grid.ColumnSpan="2" CornerRadius="20" Padding="16,12" Background="#66000000" BorderBrush="#1AFFFFFF" BorderThickness="1">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <TextBlock Text="Truco Paulista" FontSize="20" FontWeight="Bold" Foreground="{StaticResource MacTextPrimary}" />
                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MacTextYellow}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ConnectionDetails}" Foreground="{StaticResource MacTextMuted}" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Content="Idioma" Command="{Binding ToggleLocaleCommand}" Background="#33FFFFFF" Foreground="White" BorderThickness="0" CornerRadius="8"/>
                            <Button Content="Sair" Command="{Binding CloseSessionCommand}" IsEnabled="{Binding HasActiveSession}" Background="#33FF5252" Foreground="White" BorderThickness="0" CornerRadius="8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Board Area -->
                <Border x:Name="MainBoardBorder" Grid.Row="1" Grid.Column="0" CornerRadius="120" Background="{StaticResource MacFeltBrush}" BorderBrush="#26FFFFFF" BorderThickness="2" Margin="16" Padding="32">
                    <Grid>
                        <!-- Top left/right HUD (Scores and Stakes) -->
                        <Grid Visibility="{Binding GameVisibility}" VerticalAlignment="Top" Margin="0,20,0,0">
                            <!-- Left: Nos -->
                            <StackPanel HorizontalAlignment="Left" Margin="40,0,0,0">
                                <Border Style="{StaticResource MacScoreBadge}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="NÓS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MacTextMuted}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding UsScore}" FontSize="32" FontWeight="Black" Foreground="{StaticResource MacTextPrimary}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <!-- Center: Vale -->
                            <StackPanel HorizontalAlignment="Center">
                                <Border Style="{StaticResource MacStakeBadge}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="VALE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MacTextMuted}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding StakeText}" FontSize="28" FontWeight="Black" Foreground="{StaticResource MacTextYellow}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <!-- Right: Eles -->
                            <StackPanel HorizontalAlignment="Right" Margin="0,0,40,0">
                                <Border Style="{StaticResource MacScoreBadge}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ELES" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MacTextMuted}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ThemScore}" FontSize="32" FontWeight="Black" Foreground="{StaticResource MacTextPrimary}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Visibility="{Binding GameVisibility}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Opponent -->
                            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,110,0,0" Spacing="16">
                                <Border Style="{StaticResource MacPillText}">
                                    <TextBlock Text="{Binding TopSeat.Name}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource MacTextPrimary}" CharacterSpacing="10"/>
                                </Border>
                                <!-- Opponent played card summary if any -->
                                <ContentControl Content="{Binding TopSeat.PlayedCardViewModel}" ContentTemplate="{StaticResource GameCardTemplate}" />
                            </StackPanel>

                            <!-- Center Table Area -->
                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="440"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left/Right seat summaries if 4 players -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="{Binding LeftSeatVisibility}">
                                    <Border Style="{StaticResource MacPillText}">
                                        <TextBlock Text="{Binding LeftSeat.Name}" FontSize="12" Foreground="{StaticResource MacTextPrimary}"/>
                                    </Border>
                                    <ContentControl Content="{Binding LeftSeat.PlayedCardViewModel}" ContentTemplate="{StaticResource GameCardTemplate}" Margin="0,8,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{Binding RightSeatVisibility}">
                                    <Border Style="{StaticResource MacPillText}">
                                        <TextBlock Text="{Binding RightSeat.Name}" FontSize="12" Foreground="{StaticResource MacTextPrimary}"/>
                                    </Border>
                                    <ContentControl Content="{Binding RightSeat.PlayedCardViewModel}" ContentTemplate="{StaticResource GameCardTemplate}" Margin="0,8,0,0" />
                                </StackPanel>

                                <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Vira -->
                                    <StackPanel Grid.Column="0" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="VIRA" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MacTextMuted}" HorizontalAlignment="Center" CharacterSpacing="20"/>
                                        <ContentControl Content="{Binding ViraCardViewModel}" ContentTemplate="{StaticResource GameCardTemplate}" />
                                    </StackPanel>

                                    <!-- Played Cards Circle -->
                                    <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="160" Height="160" Fill="#0AFFFFFF"/>
                                        <TextBlock Text="{Binding HandSummary}" Foreground="{StaticResource MacTextMuted}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding WinnerText}" Foreground="{StaticResource MacTextMuted}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20" TextWrapping="Wrap"/>
                                        <ContentControl Content="{Binding BottomSeat.PlayedCardViewModel}" ContentTemplate="{StaticResource GameCardTemplate}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-60" />
                                    </Grid>

                                    <!-- Manilha -->
                                    <StackPanel Grid.Column="2" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="MANILHA" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MacTextMuted}" HorizontalAlignment="Center" CharacterSpacing="20"/>
                                        <ContentControl Content="{Binding ManilhaCardViewModel}" ContentTemplate="{StaticResource GameCardTemplate}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!-- Player Area -->
                            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,30" Spacing="16">

                                <Grid>
                                    <Border Background="{StaticResource MacTextYellow}" CornerRadius="12" Padding="16,6" HorizontalAlignment="Center" Visibility="{Binding BottomSeat.IsCurrentTurn, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="SUA VEZ" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MacTextDark}" CharacterSpacing="15"/>
                                    </Border>
                                </Grid>

                                <!-- Player Hand -->
                                <ItemsControl ItemsSource="{Binding BottomSeat.HandCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="-8" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource CardButtonStyle}" Command="{Binding ElementName=RootPanel, Path=DataContext.PlayCardCommand}" CommandParameter="{Binding Card}" Margin="0,0,16,0">
                                                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource GameCardTemplate}" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Action Buttons -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                                    <Button Content="TRUCO" Command="{Binding RequestTrucoCommand}" IsEnabled="{Binding CanRequestTruco}" Background="#FFF57F17" Foreground="White" FontWeight="Bold" Padding="20,10" CornerRadius="8" BorderThickness="0"/>
                                    <Button Content="Aceitar" Command="{Binding AcceptTrucoCommand}" IsEnabled="{Binding CanAnswerRaise}" Background="#FF43A047" Foreground="White" FontWeight="Bold" Padding="20,10" CornerRadius="8" BorderThickness="0"/>
                                    <Button Content="Recusar" Command="{Binding RefuseTrucoCommand}" IsEnabled="{Binding CanAnswerRaise}" Background="#FFE53935" Foreground="White" FontWeight="Bold" Padding="20,10" CornerRadius="8" BorderThickness="0"/>
                                    <Button Content="Nova mão" Command="{Binding NewHandCommand}" IsEnabled="{Binding CanStartNewHand}" Background="#33FFFFFF" Foreground="White" FontWeight="Bold" Padding="20,10" CornerRadius="8" BorderThickness="0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Non Game Screens Overlay -->
                        <!-- Home Overlay -->
                        <Grid Visibility="{Binding HomeVisibility}">
                            <Border Background="#D9000000" CornerRadius="24" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel Spacing="20" MaxWidth="560">
                                    <TextBlock Text="Truco Paulista" FontSize="36" FontWeight="Black" Foreground="{StaticResource MacTextPrimary}" HorizontalAlignment="Center" />
                                    <TextBlock Text="O clássico reintepretado." Foreground="{StaticResource MacTextMuted}" HorizontalAlignment="Center" FontSize="16"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,20,0,0">
                                        <Button Content="Partida Offline" Command="{Binding ShowOfflineSetupCommand}" Padding="24,12" CornerRadius="8" Background="{StaticResource MacTextYellow}" Foreground="{StaticResource MacTextDark}" FontWeight="Bold" BorderThickness="0"/>
                                        <Button Content="Criar Host" Command="{Binding ShowHostSetupCommand}" Padding="24,12" CornerRadius="8" Background="#33FFFFFF" Foreground="White" BorderThickness="0"/>
                                        <Button Content="Entrar Online" Command="{Binding ShowJoinSetupCommand}" Padding="24,12" CornerRadius="8" Background="#33FFFFFF" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <Grid Visibility="{Binding OfflineVisibility}">
                            <Border Background="#D9000000" CornerRadius="24" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel MaxWidth="500" Spacing="16">
                                    <TextBlock Text="Partida Offline" FontSize="28" FontWeight="Bold" Foreground="{StaticResource MacTextPrimary}"/>
                                    <TextBox Text="{Binding OfflinePlayerName, Mode=TwoWay}" PlaceholderText="Seu nome" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Padding="12" CornerRadius="8"/>
                                    <ComboBox SelectedValue="{Binding OfflineNumPlayers, Mode=TwoWay}" SelectedValuePath="Tag" Width="200" Background="#33FFFFFF" Foreground="White" BorderThickness="0" CornerRadius="8">
                                        <ComboBoxItem Content="2 jogadores" Tag="2" />
                                        <ComboBoxItem Content="4 jogadores" Tag="4" />
                                    </ComboBox>
                                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,24,0,0">
                                        <Button Content="Iniciar" Command="{Binding StartOfflineGameCommand}" Padding="24,10" Background="{StaticResource MacTextYellow}" Foreground="{StaticResource MacTextDark}" FontWeight="Bold" CornerRadius="8" BorderThickness="0"/>
                                        <Button Content="Voltar" Command="{Binding ShowHomeCommand}" Padding="24,10" Background="Transparent" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Visibility="{Binding HostVisibility}">
                            <Border Background="#D9000000" CornerRadius="24" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel MaxWidth="520" Spacing="16">
                                    <TextBlock Text="Criar Mesa Online" FontSize="28" FontWeight="Bold" Foreground="{StaticResource MacTextPrimary}"/>
                                    <TextBox Text="{Binding HostName, Mode=TwoWay}" PlaceholderText="Seu nome" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Padding="12" CornerRadius="8"/>
                                    <ComboBox SelectedValue="{Binding HostNumPlayers, Mode=TwoWay}" SelectedValuePath="Tag" Width="220" Background="#33FFFFFF" Foreground="White" BorderThickness="0" CornerRadius="8">
                                        <ComboBoxItem Content="2 jogadores" Tag="2" />
                                        <ComboBoxItem Content="4 jogadores" Tag="4" />
                                    </ComboBox>
                                    <TextBox Text="{Binding BindAddress, Mode=TwoWay}" PlaceholderText="Bind address (opcional)" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Padding="12" CornerRadius="8"/>
                                    <TextBox Text="{Binding RelayUrl, Mode=TwoWay}" PlaceholderText="Relay URL (opcional)" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Padding="12" CornerRadius="8"/>
                                    <ComboBox SelectedValue="{Binding TransportMode, Mode=TwoWay}" SelectedValuePath="Tag" Width="220" Background="#33FFFFFF" Foreground="White" BorderThickness="0" CornerRadius="8">
                                        <ComboBoxItem Content="TCP + TLS" Tag="tcp_tls" />
                                        <ComboBoxItem Content="Relay QUIC v2" Tag="relay_quic_v2" />
                                    </ComboBox>
                                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,24,0,0">
                                        <Button Content="Criar sala" Command="{Binding CreateHostSessionCommand}" Padding="24,10" Background="{StaticResource MacTextYellow}" Foreground="{StaticResource MacTextDark}" FontWeight="Bold" CornerRadius="8" BorderThickness="0"/>
                                        <Button Content="Voltar" Command="{Binding ShowHomeCommand}" Padding="24,10" Background="Transparent" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Visibility="{Binding JoinVisibility}">
                            <Border Background="#D9000000" CornerRadius="24" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel MaxWidth="500" Spacing="16">
                                    <TextBlock Text="Entrar em Mesa" FontSize="28" FontWeight="Bold" Foreground="{StaticResource MacTextPrimary}"/>
                                    <TextBox Text="{Binding JoinKey, Mode=TwoWay}" PlaceholderText="Código do Convite" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Padding="12" CornerRadius="8"/>
                                    <TextBox Text="{Binding JoinPlayerName, Mode=TwoWay}" PlaceholderText="Seu nome" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Padding="12" CornerRadius="8"/>
                                    <ComboBox SelectedValue="{Binding DesiredRole, Mode=TwoWay}" SelectedValuePath="Tag" Width="200" Background="#33FFFFFF" Foreground="White" BorderThickness="0" CornerRadius="8">
                                        <ComboBoxItem Content="Automático" Tag="auto" />
                                        <ComboBoxItem Content="Parceiro" Tag="partner" />
                                        <ComboBoxItem Content="Oponente" Tag="opponent" />
                                    </ComboBox>
                                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,24,0,0">
                                        <Button Content="Conectar" Command="{Binding JoinOnlineSessionCommand}" Padding="24,10" Background="{StaticResource MacTextYellow}" Foreground="{StaticResource MacTextDark}" FontWeight="Bold" CornerRadius="8" BorderThickness="0"/>
                                        <Button Content="Voltar" Command="{Binding ShowHomeCommand}" Padding="24,10" Background="Transparent" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Visibility="{Binding LobbyVisibility}">
                            <Border Background="#D9000000" CornerRadius="24" Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="760">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Lobby Online" FontSize="28" FontWeight="Bold" Foreground="{StaticResource MacTextPrimary}"/>
                                    <TextBlock Text="{Binding ConnectionDetails}" TextWrapping="Wrap" Foreground="{StaticResource MacTextMuted}"/>

                                    <Border Background="#1AFFFFFF" CornerRadius="12" Padding="12" Visibility="{Binding InviteVisibility}">
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                            <TextBlock Text="Convite" Foreground="{StaticResource MacTextMuted}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding InviteKey}" Foreground="{StaticResource MacTextYellow}" FontFamily="Consolas" FontSize="16" VerticalAlignment="Center"/>
                                            <Button Content="Copiar" Command="{Binding CopyInviteKeyCommand}" Background="#33FFFFFF" Foreground="White" BorderThickness="0" CornerRadius="8"/>
                                        </StackPanel>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding LobbySeats}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#14000000" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayLabel}" Foreground="{StaticResource MacTextPrimary}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MacTextMuted}" FontSize="12"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                            <Border Background="#1AFFFFFF" CornerRadius="999" Padding="8,4">
                                                                <TextBlock Text="{Binding ConnectionBadge}" Foreground="{StaticResource MacTextPrimary}" FontSize="11"/>
                                                            </Border>
                                                            <Border Background="#1AFFFFFF" CornerRadius="999" Padding="8,4">
                                                                <TextBlock Text="{Binding RoleBadge}" Foreground="{StaticResource MacTextPrimary}" FontSize="11"/>
                                                            </Border>
                                                            <Border Background="#33FFD54F" CornerRadius="999" Padding="8,4">
                                                                <TextBlock Text="{Binding ProtocolBadge}" Foreground="{StaticResource MacTextDark}" FontSize="11" FontWeight="Bold"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <Button Content="Iniciar partida" Command="{Binding StartHostedMatchCommand}" IsEnabled="{Binding CanStartHostedMatch}" Padding="24,10" Background="{StaticResource MacTextYellow}" Foreground="{StaticResource MacTextDark}" FontWeight="Bold" CornerRadius="8" BorderThickness="0"/>
                                        <TextBlock Text="O host inicia quando todos os assentos ocupados estiverem conectados." Foreground="{StaticResource MacTextMuted}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </Border>

                <!-- Floating Sidebar (Chat/Logs) -->
                <Border x:Name="SidebarBorder" Grid.Row="1" Grid.Column="1" Background="#B3111111" CornerRadius="20" Margin="0,16,0,16" Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Painel da Mesa" FontSize="20" FontWeight="Bold" Foreground="{StaticResource MacTextPrimary}"/>

                            <Border Background="#1AFFFFFF" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Eventos" FontWeight="SemiBold" Foreground="{StaticResource MacTextPrimary}"/>
                                    <TextBlock Text="{Binding InfoBannerText}" Foreground="#FF81C784" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding ErrorBannerText}" Foreground="#FFE57373" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Chat" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource MacTextPrimary}"/>
                                <Border Background="#0AFFFFFF" CornerRadius="8" MaxHeight="300" Padding="8">
                                    <ScrollViewer>
                                        <ItemsControl ItemsSource="{Binding ChatFeed}" ItemTemplate="{StaticResource ActivityEntryTemplate}" />
                                    </ScrollViewer>
                                </Border>
                                <TextBox Text="{Binding ChatInput, Mode=TwoWay}" PlaceholderText="Mensagem..." Background="#1AFFFFFF" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="10"/>
                                <Button Content="Enviar" Command="{Binding SendChatCommand}" IsEnabled="{Binding CanSendChat}" Background="#33FFFFFF" Foreground="White" CornerRadius="8" HorizontalAlignment="Right" BorderThickness="0"/>
                            </StackPanel>

                            <StackPanel Spacing="8" Margin="0,16,0,0">
                                <TextBlock Text="Histórico" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource MacTextPrimary}"/>
                                <Border Background="#0AFFFFFF" CornerRadius="8" MaxHeight="200" Padding="8">
                                    <ScrollViewer>
                                        <ItemsControl ItemsSource="{Binding MatchLog}" ItemTemplate="{StaticResource LogEntryTemplate}" />
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
