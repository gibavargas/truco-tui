<Window
    x:Class="TrucoWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:TrucoWinUI.ViewModels"
    Title="Truco Paulista">

    <Grid x:Name="RootPanel">
        <Grid.DataContext>
            <viewModels:AppShellViewModel />
        </Grid.DataContext>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4A240F" Offset="0" />
                <GradientStop Color="#140A06" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#CC101010" Padding="16" CornerRadius="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Truco Paulista" FontSize="28" FontWeight="Bold" Foreground="#FFF4EC" />
                        <TextBlock Text="{Binding StatusText}" Foreground="#FFE08D" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ConnectionDetails}" Foreground="#FFD0D0D0" TextWrapping="Wrap" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding VersionText}" Foreground="#FF8AB9FF" Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Inicio" Command="{Binding ShowHomeCommand}" Margin="0,0,8,0" />
                        <Button Content="Offline" Command="{Binding ShowOfflineSetupCommand}" Margin="0,0,8,0" />
                        <Button Content="Hospedar" Command="{Binding ShowHostSetupCommand}" Margin="0,0,8,0" />
                        <Button Content="Entrar" Command="{Binding ShowJoinSetupCommand}" Margin="0,0,8,0" />
                        <Button Content="Encerrar" Command="{Binding CloseSessionCommand}" IsEnabled="{Binding HasActiveSession}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#CC124B26" BorderBrush="#3367A15C" BorderThickness="2" CornerRadius="24" Padding="20" Margin="0,0,16,0">
                    <Grid>
                        <Grid Visibility="{Binding HomeVisibility}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
                                <TextBlock Text="Cliente WinUI 3" FontSize="48" FontWeight="Bold" Foreground="#FFF7F1E8" HorizontalAlignment="Center" />
                                <TextBlock Text="Offline, host, join, lobby, chat e mesa usam o mesmo core Go compartilhado. Esta tela existe para manter a versao Windows alinhada com as demais." TextWrapping="Wrap" TextAlignment="Center" Foreground="#FFE0E0E0" Margin="0,16,0,0" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                                    <Button Content="Partida offline" Command="{Binding ShowOfflineSetupCommand}" Margin="0,0,8,0" />
                                    <Button Content="Criar host" Command="{Binding ShowHostSetupCommand}" Margin="0,0,8,0" />
                                    <Button Content="Entrar" Command="{Binding ShowJoinSetupCommand}" />
                                </StackPanel>
                                <TextBlock Text="{Binding SeedSummary}" HorizontalAlignment="Center" Foreground="#FFB3E9C6" Margin="0,16,0,0" />
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Visibility="{Binding OfflineVisibility}" VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="760">
                                <TextBlock Text="Partida offline" FontSize="34" FontWeight="Bold" Foreground="#FFF7F1E8" />
                                <TextBlock Text="Jogador 1 e humano local. Use 2 ou 4 jogadores e, se quiser, trave a seed para replay." TextWrapping="Wrap" Foreground="#FFDADADA" Margin="0,10,0,0" />
                                <TextBlock Text="Quantidade de jogadores" Foreground="White" Margin="0,18,0,4" />
                                <ComboBox SelectedValue="{Binding OfflineNumPlayers, Mode=TwoWay}" SelectedValuePath="Tag" Width="180">
                                    <ComboBoxItem Content="2 jogadores" Tag="2" />
                                    <ComboBoxItem Content="4 jogadores" Tag="4" />
                                </ComboBox>
                                <TextBox Text="{Binding OfflinePlayer1Name, Mode=TwoWay}" PlaceholderText="Jogador 1" Margin="0,18,0,0" />
                                <TextBox Text="{Binding OfflinePlayer2Name, Mode=TwoWay}" PlaceholderText="Jogador 2" Margin="0,10,0,0" />
                                <CheckBox Content="Jogador 2 e CPU" IsChecked="{Binding OfflinePlayer2Cpu, Mode=TwoWay}" Margin="0,6,0,0" />
                                <TextBox Text="{Binding OfflinePlayer3Name, Mode=TwoWay}" PlaceholderText="Jogador 3" Margin="0,10,0,0" />
                                <CheckBox Content="Jogador 3 e CPU" IsChecked="{Binding OfflinePlayer3Cpu, Mode=TwoWay}" Margin="0,6,0,0" />
                                <TextBox Text="{Binding OfflinePlayer4Name, Mode=TwoWay}" PlaceholderText="Jogador 4" Margin="0,10,0,0" />
                                <CheckBox Content="Jogador 4 e CPU" IsChecked="{Binding OfflinePlayer4Cpu, Mode=TwoWay}" Margin="0,6,0,0" />
                                <TextBox Text="{Binding SeedLoText, Mode=TwoWay}" PlaceholderText="Seed low" Margin="0,18,0,0" />
                                <TextBox Text="{Binding SeedHiText, Mode=TwoWay}" PlaceholderText="Seed high" Margin="0,10,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                    <Button Content="Iniciar offline" Command="{Binding StartOfflineGameCommand}" Margin="0,0,8,0" />
                                    <Button Content="Voltar" Command="{Binding ShowHomeCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer Visibility="{Binding HostVisibility}" VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="760">
                                <TextBlock Text="Criar sessao host" FontSize="34" FontWeight="Bold" Foreground="#FFF7F1E8" />
                                <TextBox Text="{Binding HostName, Mode=TwoWay}" PlaceholderText="Nome do host" Margin="0,18,0,0" />
                                <ComboBox SelectedValue="{Binding HostNumPlayers, Mode=TwoWay}" SelectedValuePath="Tag" Width="180" Margin="0,12,0,0">
                                    <ComboBoxItem Content="2 jogadores" Tag="2" />
                                    <ComboBoxItem Content="4 jogadores" Tag="4" />
                                </ComboBox>
                                <TextBox Text="{Binding BindAddress, Mode=TwoWay}" PlaceholderText="Bind address" Margin="0,12,0,0" />
                                <TextBox Text="{Binding RelayUrl, Mode=TwoWay}" PlaceholderText="Relay URL" Margin="0,12,0,0" />
                                <ComboBox SelectedValue="{Binding TransportMode, Mode=TwoWay}" SelectedValuePath="Tag" Width="220" Margin="0,12,0,0">
                                    <ComboBoxItem Content="TCP/TLS" Tag="tcp_tls" />
                                    <ComboBoxItem Content="Relay QUIC v2" Tag="relay_quic_v2" />
                                </ComboBox>
                                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                    <Button Content="Criar host" Command="{Binding CreateHostSessionCommand}" Margin="0,0,8,0" />
                                    <Button Content="Voltar" Command="{Binding ShowHomeCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer Visibility="{Binding JoinVisibility}" VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="760">
                                <TextBlock Text="Entrar em sessao" FontSize="34" FontWeight="Bold" Foreground="#FFF7F1E8" />
                                <TextBox Text="{Binding JoinKey, Mode=TwoWay}" PlaceholderText="Convite" Margin="0,18,0,0" />
                                <TextBox Text="{Binding JoinPlayerName, Mode=TwoWay}" PlaceholderText="Nome do jogador" Margin="0,12,0,0" />
                                <ComboBox SelectedValue="{Binding DesiredRole, Mode=TwoWay}" SelectedValuePath="Tag" Width="220" Margin="0,12,0,0">
                                    <ComboBoxItem Content="Automatico" Tag="auto" />
                                    <ComboBoxItem Content="Parceiro" Tag="partner" />
                                    <ComboBoxItem Content="Oponente" Tag="opponent" />
                                </ComboBox>
                                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                    <Button Content="Entrar" Command="{Binding JoinOnlineSessionCommand}" Margin="0,0,8,0" />
                                    <Button Content="Voltar" Command="{Binding ShowHomeCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer Visibility="{Binding LobbyVisibility}" VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="760">
                                <TextBlock Text="Lobby online" FontSize="34" FontWeight="Bold" Foreground="#FFF7F1E8" />
                                <TextBox Text="{Binding InviteKey}" IsReadOnly="True" Margin="0,16,0,0" />
                                <Button Content="Copiar convite" Command="{Binding CopyInviteKeyCommand}" HorizontalAlignment="Left" Margin="0,8,0,0" />
                                <TextBox Text="{Binding ReplacementInviteKey}" IsReadOnly="True" Margin="0,12,0,0" Visibility="{Binding ReplacementInviteVisibility}" />
                                <ItemsControl ItemsSource="{Binding LobbySeats}" Margin="0,16,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#99111C14" BorderBrush="#334E9662" BorderThickness="1" Padding="12" CornerRadius="12" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayLabel}" Foreground="White" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding StatusText}" Foreground="#FFDADADA" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding ConnectionBadge}" Foreground="#FFB8F0C5" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding RoleBadge}" Foreground="#FF8AB9FF" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ComboBox ItemsSource="{Binding CandidateSeats}" SelectedItem="{Binding SelectedCandidateSeat, Mode=TwoWay}" DisplayMemberPath="DisplayLabel" Margin="0,8,0,0" />
                                <Button Content="Votar host" Command="{Binding VoteHostCommand}" HorizontalAlignment="Left" Margin="0,8,0,0" />
                                <ComboBox ItemsSource="{Binding ReplacementSeats}" SelectedItem="{Binding SelectedReplacementSeat, Mode=TwoWay}" DisplayMemberPath="DisplayLabel" Margin="0,16,0,0" />
                                <Button Content="Gerar convite de reposicao" Command="{Binding RequestReplacementInviteCommand}" HorizontalAlignment="Left" Margin="0,8,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                    <Button Content="Iniciar partida" Command="{Binding StartHostedMatchCommand}" IsEnabled="{Binding CanStartHostedMatch}" Margin="0,0,8,0" />
                                    <Button Content="Encerrar sessao" Command="{Binding CloseSessionCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer Visibility="{Binding GameVisibility}" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentTurnText}" Foreground="#FFF7F1E8" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding HandSummary}" Foreground="#FFDADADA" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding PendingRaiseText}" Foreground="#FFFFD166" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding WinnerText}" Foreground="#FFFFD166" HorizontalAlignment="Center" Margin="0,8,0,16" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding LeftSeat.Name}" Foreground="White" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding LeftSeat.TeamLabel}" Foreground="#FFDADADA" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding LeftSeat.PlayedCardLabel}" Foreground="#FFFFD166" FontSize="22" Margin="0,6,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding ViraText}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding ManilhaText}" Foreground="#FFDADADA" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding StakeText}" Foreground="#FFFFD166" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                        <TextBlock Text="Nos" Foreground="#FFDADADA" HorizontalAlignment="Center" Margin="0,16,0,0" />
                                        <TextBlock Text="{Binding UsScore}" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Eles" Foreground="#FFDADADA" HorizontalAlignment="Center" Margin="0,12,0,0" />
                                        <TextBlock Text="{Binding ThemScore}" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding RightSeat.Name}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding RightSeat.TeamLabel}" Foreground="#FFDADADA" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding RightSeat.PlayedCardLabel}" Foreground="#FFFFD166" FontSize="22" HorizontalAlignment="Right" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding TopSeat.Name}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,0" />
                                <TextBlock Text="{Binding TopSeat.PlayedCardLabel}" Foreground="#FFFFD166" FontSize="22" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding BottomSeat.Name}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,20,0,0" />
                                <TextBlock Text="{Binding BottomSeat.TeamLabel}" Foreground="#FFDADADA" HorizontalAlignment="Center" Margin="0,4,0,0" />

                                <ItemsControl ItemsSource="{Binding BottomSeat.Hand}" Margin="0,16,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding ElementName=RootPanel, Path=DataContext.PlayCardCommand}" CommandParameter="{Binding}" IsEnabled="{Binding ElementName=RootPanel, Path=DataContext.CanPlayCards}" Background="#FFF6F0E8" BorderBrush="#FFB07F26" Padding="12" MinWidth="96" Margin="0,0,10,0">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Rank}" Foreground="#FF1B0E08" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding SuitSymbol}" Foreground="#FF1B0E08" FontSize="24" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                                    <Button Content="Truco / subir" Command="{Binding RequestTrucoCommand}" IsEnabled="{Binding CanRequestTruco}" Margin="0,0,8,0" />
                                    <Button Content="Aceitar" Command="{Binding AcceptTrucoCommand}" IsEnabled="{Binding CanAnswerRaise}" Margin="0,0,8,0" />
                                    <Button Content="Recusar" Command="{Binding RefuseTrucoCommand}" IsEnabled="{Binding CanAnswerRaise}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#CC111111" Padding="16" CornerRadius="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Painel lateral" FontSize="22" FontWeight="Bold" Foreground="#FFF7F1E8" />
                            <TextBlock Text="{Binding CurrentModeText}" Foreground="#FF8AB9FF" Margin="0,6,0,0" />
                            <Border Background="#66334A2C" Padding="10" CornerRadius="10" Margin="0,14,0,0">
                                <TextBlock Text="{Binding InfoBannerText}" Foreground="#FFB8F0C5" TextWrapping="Wrap" />
                            </Border>
                            <Border Background="#664A1F1F" Padding="10" CornerRadius="10" Margin="0,10,0,0">
                                <TextBlock Text="{Binding ErrorBannerText}" Foreground="#FFFFB0B0" TextWrapping="Wrap" />
                            </Border>
                            <TextBlock Text="Chat" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,16,0,8" />
                            <ListView ItemsSource="{Binding ChatFeed}" MaxHeight="220" />
                            <TextBox Text="{Binding ChatInput, Mode=TwoWay}" PlaceholderText="Mensagem ou comando" Margin="0,8,0,0" />
                            <Button Content="Enviar" Command="{Binding SendChatCommand}" IsEnabled="{Binding CanSendChat}" Margin="0,8,0,0" />
                            <TextBlock Text="Historico da partida" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,20,0,8" />
                            <ListView ItemsSource="{Binding MatchLog}" MaxHeight="180" />
                            <TextBlock Text="Diagnosticos" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,20,0,8" />
                            <ListView ItemsSource="{Binding DiagnosticsLog}" MaxHeight="180" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
