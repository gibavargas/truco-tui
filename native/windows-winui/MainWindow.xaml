<Window
    x:Class="TrucoWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Truco - Native Windows">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootPanel" Background="#111827">
        <Grid.Resources>
            <Style x:Key="SurfaceCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#CC172033" />
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="BorderBrush" Value="#33556B93" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="MinHeight" Value="44" />
            </Style>

            <Style x:Key="SidebarTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="White" />
            </Style>

            <Style x:Key="MetricValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="White" />
            </Style>
        </Grid.Resources>

        <Border Margin="20" CornerRadius="28" Background="#CC0F172A">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Truco" FontSize="36" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="{Binding MatchStatusText}" Foreground="#FFD6E4FF" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#331D4ED8"
                            BorderBrush="#664F46E5"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="14,8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Modo" Foreground="#FF93C5FD" />
                            <TextBlock Text="{Binding Mode}" Foreground="White" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid Visibility="{Binding VisibilityIfNotPlaying}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SurfaceCardStyle}" Margin="0,0,16,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="20">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Portable Windows client" FontSize="14" Foreground="#FF93C5FD" />
                                        <TextBlock Text="WinUI 3 front-end backed by the shared Go runtime." FontSize="28" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" />
                                        <TextBlock Text="Offline, host, and join flows all talk to the same FFI runtime used by the other native clients." Foreground="#FFC7D2FE" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="12">
                                            <TextBox Header="Player name" Text="{Binding SetupPlayerName, Mode=TwoWay}" />
                                            <ComboBox Header="Players" SelectedIndex="{Binding SetupNumPlayersIndex, Mode=TwoWay}">
                                                <ComboBoxItem Content="2 players" />
                                                <ComboBoxItem Content="4 players" />
                                            </ComboBox>
                                            <ComboBox Header="Locale" SelectedIndex="{Binding SetupLocaleIndex, Mode=TwoWay}">
                                                <ComboBoxItem Content="Portuguese (Brazil)" />
                                                <ComboBoxItem Content="English (US)" />
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="12">
                                            <TextBox Header="Relay URL (optional)" Text="{Binding SetupRelayUrl, Mode=TwoWay}" />
                                            <ComboBox Header="Desired role" SelectedIndex="{Binding SetupDesiredRoleIndex, Mode=TwoWay}">
                                                <ComboBoxItem Content="Auto" />
                                                <ComboBoxItem Content="Partner" />
                                                <ComboBoxItem Content="Opponent" />
                                            </ComboBox>
                                            <TextBox Header="Invite key" PlaceholderText="Paste an online invite key" Text="{Binding InviteKeyInput, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Background="#331E293B" CornerRadius="16" Padding="16">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Table preview" Style="{StaticResource SidebarTitleStyle}" />
                                            <ItemsControl ItemsSource="{Binding SetupPlayerLabels}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#3326364D" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                                            <TextBlock Text="{Binding}" Foreground="White" TextWrapping="Wrap" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#66B91C1C"
                                            BorderBrush="#66FCA5A5"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="14"
                                            Visibility="{Binding VisibilityIfLastActionError}">
                                        <TextBlock Text="{Binding CombinedErrorText}" Foreground="#FFFEE2E2" TextWrapping="Wrap" />
                                    </Border>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Content="Start offline"
                                                Command="{Binding StartGameCommand}"
                                                Background="#FFF59E0B"
                                                Foreground="Black" />
                                        <Button Grid.Column="1"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Content="Host online"
                                                Command="{Binding HostOnlineGameCommand}"
                                                Background="#FF1D4ED8"
                                                Foreground="White" />
                                        <Button Grid.Column="2"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Content="Join"
                                                Command="{Binding JoinOnlineGameCommand}"
                                                Background="#FF0F766E"
                                                Foreground="White" />
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="16">
                            <Border Style="{StaticResource SurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Runtime diagnostics" Style="{StaticResource SidebarTitleStyle}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Connection" Foreground="#FF93C5FD" />
                                        <TextBlock Text="{Binding ConnectionStatusText}" Foreground="White" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Mode" Foreground="#FF93C5FD" />
                                        <TextBlock Text="{Binding ConnectionModeText}" Foreground="White" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding VisibilityIfConnectionRole}">
                                        <TextBlock Text="Role" Foreground="#FF93C5FD" />
                                        <TextBlock Text="{Binding ConnectionRoleText}" Foreground="White" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Queued events" Foreground="#FF93C5FD" />
                                        <TextBlock Text="{Binding EventBacklogText}" Foreground="White" />
                                    </StackPanel>
                                    <Button Content="Refresh state" Command="{Binding RefreshStateCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Readiness" Style="{StaticResource SidebarTitleStyle}" />
                                    <TextBlock Text="This portable client prefers `truco-core-ffi.dll` next to the executable and falls back to an embedded runtime when needed." Foreground="#FFC7D2FE" TextWrapping="Wrap" />
                                    <TextBlock Text="Use the WinUI build script to publish into the repository's `bin/gui/winui` portable bundle." Foreground="#FFC7D2FE" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Visibility="{Binding VisibilityIfOnlineLobby}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="16" Margin="0,0,16,0">
                            <Border Style="{StaticResource SurfaceCardStyle}">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Online lobby" FontSize="28" FontWeight="Bold" Foreground="White" />
                                    <TextBlock Text="{Binding LobbyStatusText}" Foreground="#FFD6E4FF" TextWrapping="Wrap" />

                                    <Border Background="#331D4ED8" CornerRadius="14" Padding="12" Visibility="{Binding VisibilityIfInviteKey}">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Invite key" Foreground="#FF93C5FD" />
                                                <TextBlock Text="{Binding InviteKeyText}" FontSize="24" FontWeight="Bold" Foreground="White" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Copy" Command="{Binding CopyInviteKeyCommand}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding LobbySlots}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#3326364D" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Label}" Foreground="White" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding StatusText}" Foreground="#FFF59E0B" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="Vote host"
                                                                Command="{Binding DataContext.VoteHostCommand, ElementName=RootPanel}"
                                                                CommandParameter="{Binding Seat}"
                                                                IsEnabled="{Binding CanVote}"
                                                                Margin="0,0,8,0" />
                                                        <Button Grid.Column="2"
                                                                Content="Replacement invite"
                                                                Command="{Binding DataContext.RequestReplacementInviteCommand, ElementName=RootPanel}"
                                                                CommandParameter="{Binding Seat}"
                                                                IsEnabled="{Binding CanReplace}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="Start match"
                                                Command="{Binding StartHostedMatchCommand}"
                                                Visibility="{Binding VisibilityIfHost}"
                                                Background="#FF15803D"
                                                Foreground="White" />
                                        <Button Grid.Column="1"
                                                Content="Refresh"
                                                Command="{Binding RefreshStateCommand}" />
                                        <Button Grid.Column="2"
                                                Content="Leave lobby"
                                                Command="{Binding LeaveOnlineGameCommand}"
                                                IsEnabled="{Binding CanCloseSession}"
                                                HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="16">
                            <Border Style="{StaticResource SurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Lobby chat" Style="{StaticResource SidebarTitleStyle}" />
                                    <ScrollViewer Height="280" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ChatEvents}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,8" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <TextBox PlaceholderText="Say something to the table" Text="{Binding ChatMessage, Mode=TwoWay}" />
                                    <Button Content="Send" Command="{Binding SendChatCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Lobby event feed" Style="{StaticResource SidebarTitleStyle}" />
                                    <ScrollViewer Height="220" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding LobbyEventEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#FFC7D2FE" TextWrapping="Wrap" Margin="0,0,0,8" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Visibility="{Binding VisibilityIfPlaying}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#331E293B" CornerRadius="18" Padding="16" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Us" Foreground="#FF93C5FD" />
                                    <TextBlock Text="{Binding UsPoints}" Style="{StaticResource MetricValueStyle}" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#FFF59E0B" CornerRadius="16" Padding="18,10" HorizontalAlignment="Center">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Stake" HorizontalAlignment="Center" Foreground="Black" />
                                        <TextBlock Text="{Binding Snapshot.CurrentHand.Stake, FallbackValue=1}" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black" />
                                    </StackPanel>
                                </Border>
                                <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                                    <TextBlock Text="Them" Foreground="#FF93C5FD" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding ThemPoints}" Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="16">
                            <Border Style="{StaticResource SurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Round" Style="{StaticResource SidebarTitleStyle}" />
                                    <TextBlock Text="{Binding RoundText}" Foreground="White" />
                                    <TextBlock Text="{Binding TurnIndicatorText}" FontSize="22" FontWeight="Bold" Foreground="#FFF59E0B" />
                                    <TextBlock Text="{Binding TurnPlayerName}" Foreground="#FFD6E4FF" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding CombinedErrorText}" Foreground="#FFFCA5A5" TextWrapping="Wrap" Visibility="{Binding VisibilityIfCombinedError}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Match log" Style="{StaticResource SidebarTitleStyle}" />
                                    <ScrollViewer Height="220" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding MatchLogEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#FFC7D2FE" TextWrapping="Wrap" Margin="0,0,0,8" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SurfaceCardStyle}" Margin="16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,20">
                                    <TextBlock Text="{Binding TopPlayer.Name}" Foreground="White" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding TopPlayerRoleBadge}" Foreground="#FFF59E0B" HorizontalAlignment="Center" />
                                    <ItemsControl ItemsSource="{Binding TopPlayer.Hand}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="56" Height="88" Margin="4,0,4,0" Background="#334155" CornerRadius="10" BorderBrush="#66748AA6" BorderThickness="1">
                                                    <TextBlock Text="✦" Foreground="#FFD6E4FF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Spacing="8"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding LeftPlayerVisibility}">
                                        <TextBlock Text="{Binding LeftPlayer.Name}" Foreground="White" HorizontalAlignment="Center" />
                                        <ItemsControl ItemsSource="{Binding LeftPlayer.Hand}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="78" Height="48" Margin="0,4,0,4" Background="#334155" CornerRadius="10" BorderBrush="#66748AA6" BorderThickness="1">
                                                        <TextBlock Text="✦" Foreground="#FFD6E4FF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid HorizontalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="96" Height="136" Margin="0,0,16,0" Background="#FFF8FAFC" CornerRadius="16" Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Vira" Foreground="#FF334155" />
                                                    <TextBlock Text="{Binding Snapshot.CurrentHand.Vira.Rank, FallbackValue=?}" FontSize="20" FontWeight="Bold" Foreground="#FF0F172A" />
                                                    <TextBlock Text="{Binding Snapshot.CurrentHand.Vira.SuitSymbol, FallbackValue=♠}" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Snapshot.CurrentHand.Vira.ColorBrush, FallbackValue=Black}" />
                                                </StackPanel>
                                            </Border>

                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Snapshot.CurrentHand.RoundCards}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="96" Height="136" Margin="4,0,4,0" Background="#FFF8FAFC" CornerRadius="16" Padding="12" BorderBrush="#FFE2E8F0" BorderThickness="1">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Card.Rank}" FontSize="20" FontWeight="Bold" Foreground="#FF0F172A" />
                                                                <TextBlock Text="{Binding Card.SuitSymbol}" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Card.ColorBrush, FallbackValue=Black}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Border Grid.Column="2" Width="96" Height="136" Margin="16,0,0,0" Background="#332C5282" CornerRadius="16" Padding="12" BorderBrush="#665FA7FF" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="Manilha" Foreground="#FFBFDBFE" />
                                                    <TextBlock Text="{Binding Snapshot.CurrentHand.Manilha, FallbackValue=4}" FontSize="42" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Background="#FFF59E0B" CornerRadius="999" Padding="14,8" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding MatchStatusText}" Foreground="Black" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding RightPlayer.Name}" Foreground="White" HorizontalAlignment="Center" />
                                        <ItemsControl ItemsSource="{Binding RightPlayer.Hand}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="78" Height="48" Margin="0,4,0,4" Background="#334155" CornerRadius="10" BorderBrush="#66748AA6" BorderThickness="1">
                                                        <TextBlock Text="✦" Foreground="#FFD6E4FF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,20,0,16">
                                    <Button Content="{Binding AskTrucoLabel}"
                                            Command="{Binding RequestTrucoCommand}"
                                            Visibility="{Binding VisibilityIfAskTruco}"
                                            Background="#FFB91C1C"
                                            Foreground="White" />
                                    <Button Content="Accept"
                                            Command="{Binding AcceptTrucoCommand}"
                                            Visibility="{Binding VisibilityIfShowTruco}"
                                            Background="#FF15803D"
                                            Foreground="White" />
                                    <Button Content="{Binding TrucoLabel}"
                                            Command="{Binding RequestTrucoCommand}"
                                            Visibility="{Binding VisibilityIfShowTruco}"
                                            Background="#FFEA580C"
                                            Foreground="White" />
                                    <Button Content="Fold"
                                            Command="{Binding RefuseTrucoCommand}"
                                            Visibility="{Binding VisibilityIfShowTruco}" />
                                </StackPanel>

                                <StackPanel Grid.Row="3" Spacing="14">
                                    <Border Background="#660F172A" CornerRadius="16" Padding="14" Visibility="{Binding VisibilityIfMatchOver}">
                                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding MatchResultText}" FontSize="36" FontWeight="Bold" Foreground="#FFF59E0B" HorizontalAlignment="Center" />
                                            <Button Content="Back to setup" Command="{Binding BackToSetupCommand}" IsEnabled="{Binding CanCloseSession}" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Me.Hand}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.PlayCardCommand, ElementName=RootPanel}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding DataContext.CanPlayCards, ElementName=RootPanel}"
                                                        Margin="8,0,8,0"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0">
                                                    <Border Width="108" Height="156" Background="#FFF8FAFC" CornerRadius="18" Padding="14" BorderBrush="#FFE2E8F0" BorderThickness="1">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Rank}" FontSize="24" FontWeight="Bold" Foreground="#FF0F172A" />
                                                            <TextBlock Text="{Binding SuitSymbol}" FontSize="54" Foreground="{Binding ColorBrush, FallbackValue=Black}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Grid.Column="2" Spacing="16">
                            <Border Style="{StaticResource SurfaceCardStyle}" Visibility="{Binding VisibilityIfOnlineMatch}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Live chat" Style="{StaticResource SidebarTitleStyle}" />
                                    <ScrollViewer Height="220" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ChatEvents}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,8" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <TextBox PlaceholderText="Message the table" Text="{Binding ChatMessage, Mode=TwoWay}" />
                                    <Button Content="Send" Command="{Binding SendChatCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Runtime events" Style="{StaticResource SidebarTitleStyle}" />
                                    <ScrollViewer Height="220" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding EventLogEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#FFC7D2FE" TextWrapping="Wrap" Margin="0,0,0,8" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Session controls" Style="{StaticResource SidebarTitleStyle}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Connection" Foreground="#FF93C5FD" />
                                        <TextBlock Text="{Binding ConnectionStatusText}" Foreground="White" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Backlog" Foreground="#FF93C5FD" />
                                        <TextBlock Text="{Binding EventBacklogText}" Foreground="White" />
                                    </StackPanel>
                                    <Button Content="Refresh state" Command="{Binding RefreshStateCommand}" HorizontalAlignment="Left" />
                                    <Button Content="Leave match"
                                            Command="{Binding LeaveMatchCommand}"
                                            IsEnabled="{Binding CanCloseSession}"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding VisibilityIfOnlineMatch}" />
                                    <Button Content="Back to setup" Command="{Binding BackToSetupCommand}" IsEnabled="{Binding CanCloseSession}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
