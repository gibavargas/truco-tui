<Window x:Class="TrucoWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TrucoWPF.ViewModels"
        Title="Truco - Native Windows"
        Width="1280" Height="800"
        Background="#1a1a2e">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Grid>
        <!-- Setup Screen -->
        <StackPanel Visibility="{Binding VisibilityIfNotPlaying}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="TRUCO" FontSize="64" FontWeight="Bold" Foreground="#FFCC00" 
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>
            
            <TextBlock Text="Configuracao" FontSize="24" Foreground="White" Margin="0,0,0,20"/>
            
            <TextBlock Text="Seu Nome:" Foreground="White" Margin="0,0,0,5"/>
            <TextBox Text="{Binding SetupPlayerName, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300" Height="40" FontSize="18" Margin="0,0,0,20"/>
            
            <TextBlock Text="Numero de Jogadores:" Foreground="White" Margin="0,0,0,5"/>
            <ComboBox SelectedIndex="{Binding SetupNumPlayers}" Width="300" Height="40" FontSize="18" Margin="0,0,0,20">
                <ComboBoxItem Content="2 Jogadores"/>
                <ComboBoxItem Content="4 Jogadores"/>
            </ComboBox>
            
            <TextBlock Text="Idioma:" Foreground="White" Margin="0,0,0,5"/>
            <ComboBox SelectedIndex="{Binding SetupLocaleIndex}" Width="300" Height="40" FontSize="18" Margin="0,0,0,30">
                <ComboBoxItem Content="Portugues (Brasil)"/>
                <ComboBoxItem Content="English (US)"/>
            </ComboBox>
            
            <Button Content="INICIAR JOGO" Command="{Binding StartGameCommand}"
                    Background="#00AA00" Foreground="White" FontSize="20" FontWeight="Bold"
                    Width="300" Height="50" Cursor="Hand" Margin="0,0,0,10">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="CRIAR SALA (HOST)" Command="{Binding HostOnlineGameCommand}"
                    Background="#2e5a88" Foreground="White" FontSize="18" FontWeight="Bold"
                    Width="300" Height="40" Cursor="Hand" Margin="0,0,0,15">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel Orientation="Horizontal" Width="300">
                <TextBox Text="{Binding InviteKeyInput, UpdateSourceTrigger=PropertyChanged}" 
                         Width="200" Height="40" FontSize="16" Margin="0,0,10,0" Padding="5"/>
                <Button Content="ENTRAR" Command="{Binding JoinOnlineGameCommand}"
                        Background="#885a2e" Foreground="White" FontSize="16" FontWeight="Bold"
                        Width="90" Height="40" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Online Lobby Screen -->
        <Grid Visibility="{Binding VisibilityIfOnlineLobby}" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Lobby Slots & Controls -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="SALA ONLINE" FontSize="48" FontWeight="Bold" Foreground="#FFCC00" Margin="0,0,0,20"/>
                
                <StackPanel Visibility="{Binding VisibilityIfInviteKey}" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="Chave de Convite:" Foreground="LightGray" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding LobbySnapshot.InviteKey, Mode=OneWay}" IsReadOnly="True" 
                             Background="Transparent" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding LobbySlots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#222" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}" FontSize="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <Border Background="{Binding StatusColor}" CornerRadius="4" Padding="5,2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="Bold" Foreground="Black"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="SUBSTITUIR" Command="{Binding DataContext.RequestReplacementInviteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding CanReplace, Converter={StaticResource BoolToVisibility}}"
                                                Background="#aa5500" Foreground="White" Padding="10,5" Margin="0,0,10,0" Cursor="Hand"/>
                                        <Button Content="VOTAR HOST" Command="{Binding DataContext.VoteHostCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding CanVote, Converter={StaticResource BoolToVisibility}}"
                                                Background="#2e5a88" Foreground="White" Padding="10,5" Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <Button Content="INICIAR PARTIDA" Command="{Binding StartHostedMatchCommand}"
                            Visibility="{Binding VisibilityIfHost}"
                            Background="#00AA00" Foreground="White" FontSize="18" FontWeight="Bold"
                            Width="200" Height="40" Margin="0,0,20,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="SAIR DA SALA" Command="{Binding LeaveOnlineGameCommand}"
                            Background="#990000" Foreground="White" FontSize="18" FontWeight="Bold"
                            Width="200" Height="40" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Chat Panel -->
            <Border Grid.Column="1" Background="#111" CornerRadius="12" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="CHAT DA SALA" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <ItemsControl ItemsSource="{Binding ChatEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="LightGray" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="14"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" Text="{Binding ChatMessage, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#333" Foreground="White" BorderThickness="0" Padding="8" FontSize="14" Margin="0,0,10,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendChatCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="Enviar" Command="{Binding SendChatCommand}"
                                Background="#2e5a88" Foreground="White" Padding="15,8" Cursor="Hand">
                             <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Game Screen -->
        <Grid Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Top Player -->
            <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
                <TextBlock Text="{Binding TopPlayer.Name}" FontSize="16" FontWeight="Bold" Foreground="LightGray" HorizontalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding TopPlayer.Hand}" Margin="0,10,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="50" Height="70" Background="#113e25" CornerRadius="4" 
                                    BorderBrush="#88FFFFFF" BorderThickness="1" Margin="-30,0,0,0">
                                <TextBlock Text="*" Foreground="#88FFFFFF" FontSize="24" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Left Player -->
            <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" 
                        Visibility="{Binding LeftPlayerVisibility}" Margin="10,0,0,0">
                <TextBlock Text="{Binding LeftPlayer.Name}" FontSize="14" FontWeight="Bold" Foreground="LightGray"/>
                <ItemsControl ItemsSource="{Binding LeftPlayer.Hand}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="40" Height="56" Background="#113e25" CornerRadius="4" 
                                    BorderBrush="#88FFFFFF" BorderThickness="1" Margin="0,-40,0,0">
                                <TextBlock Text="*" Foreground="#88FFFFFF" FontSize="18" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Right Player -->
            <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock Text="{Binding RightPlayer.Name}" FontSize="14" FontWeight="Bold" Foreground="LightGray"/>
                <ItemsControl ItemsSource="{Binding RightPlayer.Hand}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="40" Height="56" Background="#113e25" CornerRadius="4" 
                                    BorderBrush="#88FFFFFF" BorderThickness="1" Margin="0,-40,0,0">
                                <TextBlock Text="*" Foreground="#88FFFFFF" FontSize="18" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Center - Table -->
            <Grid Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="400" Height="250" Background="#0d2818" CornerRadius="20" BorderBrush="#2d5a3d" BorderThickness="3">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Score -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border Background="#0066cc" CornerRadius="10" Padding="15,5" Margin="0,0,10,0">
                                <TextBlock FontSize="24" FontWeight="Bold" Foreground="White">
                                    <Run Text="{Binding UsPoints}"/> - <Run Text="{Binding ThemPoints}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        
                        <!-- Vira -->
                        <TextBlock Text="{Binding Snapshot.CurrentHand.Vira.DisplayText}" FontSize="16" Foreground="#FFCC00" 
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        
                        <!-- Round Cards -->
                        <ItemsControl ItemsSource="{Binding Snapshot.CurrentHand.RoundCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="70" Height="100" Background="White" CornerRadius="6" 
                                            BorderBrush="LightGray" BorderThickness="1" Margin="-20,0,0,0">
                                        <TextBlock Text="{Binding Card.DisplayText}" FontSize="16" 
                                                   Foreground="{Binding Card.ColorBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Round indicator -->
                        <TextBlock Text="{Binding RoundText}" FontSize="14" Foreground="LightGray" 
                                   HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Truco Buttons -->
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button Content="{Binding TrucoLabel}" Command="{Binding RequestTrucoCommand}"
                        Visibility="{Binding ShowAskTruco, Converter={StaticResource BoolToVisibility}}"
                        Background="#FF0000" Foreground="White" FontWeight="Bold"
                        Width="120" Height="40" Margin="0,0,10,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                
                <StackPanel Orientation="Horizontal" Visibility="{Binding ShowTrucoActions, Converter={StaticResource BoolToVisibility}}">
                    <Button Content="ACEITAR" Command="{Binding AcceptTrucoCommand}"
                            Background="#00AA00" Foreground="White" FontWeight="Bold"
                            Width="100" Height="40" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="CORRER" Command="{Binding RefuseTrucoCommand}"
                            Background="#333333" Foreground="White" FontWeight="Bold"
                            Width="100" Height="40">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- My Cards (Bottom) -->
            <ItemsControl Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" 
                          ItemsSource="{Binding Me.Hand}"
                          HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.PlayCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="10,0,0,0">
                            <Border Width="90" Height="130" Background="White" CornerRadius="8" 
                                    BorderBrush="Gray" BorderThickness="2">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Rank}" FontSize="28" FontWeight="Bold" 
                                               Foreground="{Binding ColorBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SuitSymbol}" FontSize="24" 
                                               Foreground="{Binding ColorBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Game Chat Overlay -->
            <StackPanel Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,20,20" Width="300"
                        Visibility="{Binding VisibilityIfOnlineLobby}">
                <Border Background="#111" CornerRadius="8" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Chat" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,5">
                            <ItemsControl ItemsSource="{Binding ChatEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="LightGray" TextWrapping="Wrap" FontSize="12"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ChatMessage, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="#333" Foreground="White" BorderThickness="0" Padding="5" FontSize="12">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SendChatCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Content="►" Command="{Binding SendChatCommand}"
                                    Background="#2e5a88" Foreground="White" Padding="8,4" Margin="5,0,0,0" Cursor="Hand">
                                 <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
                <Button Content="SAIR DA SALA" Command="{Binding LeaveOnlineGameCommand}"
                        Background="#990000" Foreground="White" FontSize="12" FontWeight="Bold"
                        Height="30" Margin="0,10,0,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>
</Window>
