<Application x:Class="TrucoWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="PrimaryGreen" Color="#113e25"/>
            <SolidColorBrush x:Key="CardBackBrush" Color="#113e25"/>
            <SolidColorBrush x:Key="GoldAccent" Color="#FFCC00"/>
            <SolidColorBrush x:Key="RedButton" Color="#FF0000"/>
            <SolidColorBrush x:Key="GreenButton" Color="#00AA00"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
