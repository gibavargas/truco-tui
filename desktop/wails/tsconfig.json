{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "skipLibCheck": true
  },
  "include": ["frontend/src/**/*.ts"],
  "exclude": ["frontend/src/**/*.test.ts"]
}
