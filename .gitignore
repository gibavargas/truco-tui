# Binaries
bin/
*.exe
*.exe*.dll
*.so
*.dylib

# Native build output (per client)
native/**/bin/
native/**/obj/
native/**/target/

# Test binary
*.test

# Output of go coverage
*.out

# Go workspace file
go.work

# IDE
.vscode/
.idea/

# Browser edition build output
browser-edition/dist/

# OS
.DS_Store
Thumbs.db

# Local Codex/Claude workspace files
.claude/
.codex/

# Python cache generated by helper scripts
scripts/__pycache__/

# Xcode user-specific state
**/xcuserdata/
*.xcuserstate
